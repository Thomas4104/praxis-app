    organization_id = db.Column(db.Integer, db.ForeignKey('organizations.id'), nullable=False)
    sender = db.Column(db.String(300))
    receiver = db.Column(db.String(300))
    received = db.Column(db.DateTime, nullable=False)
    subject = db.Column(db.String(500))
    message_text = db.Column(db.Text)
    message_html = db.Column(db.Text)
    message_id = db.Column(db.String(300))  # RFC Message-ID
    response_to_id = db.Column(db.String(300))  # In-Reply-To
    response_to_inbox_id = db.Column(db.BigInteger)
    patient_id = db.Column(db.Integer, db.ForeignKey('patients.id'))
    handled_by_id = db.Column(db.Integer, db.ForeignKey('employees.id'))
    read_date = db.Column(db.DateTime)
    handled_date = db.Column(db.DateTime)
    is_deleted = db.Column(db.Boolean, default=False)
    is_spam = db.Column(db.Boolean, default=False)
    color_code = db.Column(db.Integer)
    email_folder_id = db.Column(db.Integer, db.ForeignKey('email_folders.id'))
    html_file_key = db.Column(db.String(200))
    created_at = db.Column(db.DateTime, default=lambda: datetime.now(timezone.utc))

    patient = db.relationship('Patient', backref='inbox_emails')
    handled_by = db.relationship('Employee', backref='handled_emails')
    email_folder = db.relationship('EmailFolder')


