class ReservedTime(db.Model):
    """Reservierte Zeiten / Sperrzeiten (Cenplex: ReservedtimeDto)
    Universell: Urlaub, Blocker, Schulung, etc."""
    __tablename__ = 'reserved_times'
    __table_args__ = (
        db.Index('ix_reserved_emp_time', 'employee_id', 'start_time', 'end_time'),
    )
    id = db.Column(db.Integer, primary_key=True)
    organization_id = db.Column(db.Integer, db.ForeignKey('organizations.id'))
    employee_id = db.Column(db.Integer, db.ForeignKey('employees.id'))
    patient_id = db.Column(db.Integer, db.ForeignKey('patients.id'))
    resource_id = db.Column(db.Integer, db.ForeignKey('resources.id'))
    room_id = db.Column(db.Integer, db.ForeignKey('resources.id'))
    location_id = db.Column(db.Integer, db.ForeignKey('locations.id'))
    workplan_id = db.Column(db.Integer, db.ForeignKey('employee_workplans.id'))
    treatment_site_id = db.Column(db.Integer, db.ForeignKey('treatment_sites.id'))
    start_time = db.Column(db.DateTime, nullable=False)
    end_time = db.Column(db.DateTime, nullable=False)
    title = db.Column(db.String(200))
    reserved_type = db.Column(db.Integer, default=0)  # 0=Blocker, 1=Urlaub, 2=Schulung, 3=Intern
    is_vacation = db.Column(db.Boolean, default=False)
    vacation_type = db.Column(db.Integer, default=0)
    is_halfday = db.Column(db.Boolean, default=False)
    is_global = db.Column(db.Boolean, default=False)
    is_yearly = db.Column(db.Boolean, default=False)
