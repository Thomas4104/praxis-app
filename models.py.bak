    planned_location_id = db.Column(db.Integer, db.ForeignKey('locations.id'))
    planning_batch_id = db.Column(db.Integer)
    receiver = db.Column(db.String(200))
    created_at = db.Column(db.DateTime, default=lambda: datetime.now(timezone.utc))

    employee = db.relationship('Employee', foreign_keys=[employee_id], backref=db.backref('reserved_times', lazy='dynamic'))
    patient = db.relationship('Patient', backref=db.backref('reserved_times', lazy='dynamic'))
    resource = db.relationship('Resource', foreign_keys=[resource_id])
    room = db.relationship('Resource', foreign_keys=[room_id])
    location = db.relationship('Location', foreign_keys=[location_id])
    planned_location = db.relationship('Location', foreign_keys=[planned_location_id])
    workplan = db.relationship('EmployeeWorkplan', backref='reserved_times')
    treatment_site = db.relationship('TreatmentSite')


