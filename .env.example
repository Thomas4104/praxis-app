# OMNIA Praxissoftware - Umgebungsvariablen
# WICHTIG: Alle Werte muessen vor Produktivbetrieb gesetzt werden!
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Flask-Umgebung: development | production
FLASK_ENV=production

# Geheimer Schluessel fuer Session-Verschluesselung und CSRF-Schutz
# MUSS gesetzt werden! Generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Datenbank-URI
# Entwicklung (SQLite): sqlite:///praxis.db
# Produktion (PostgreSQL): postgresql://benutzer:passwort@host:5432/datenbankname
DATABASE_URI=

# PostgreSQL-Passwort (fuer Docker-Compose)
# Starkes Passwort generieren: python -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=

# Anthropic KI-API Schluessel (fuer KI-Funktionen)
# Von console.anthropic.com
ANTHROPIC_API_KEY=

# Anthropic Modell
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Celery Message-Broker (fuer Hintergrund-Aufgaben)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Feld-Level-Verschluesselung fuer sensible Patientendaten (AHV-Nr, Diagnosen etc.)
# MUSS gesetzt werden! Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Optional: Salt fuer Key-Ableitung (nur noetig wenn ENCRYPTION_KEY kein Fernet-Key ist)
ENCRYPTION_SALT=
