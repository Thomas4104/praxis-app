# === OMNIA Praxissoftware - Umgebungsvariablen ===
# Kopiere diese Datei zu .env und setze ALLE Werte!
# NIEMALS .env in Git committen!
#   cp .env.example .env

# === Flask ===
FLASK_ENV=production
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# === Datenbank ===
DB_USER=omnia
# Generieren: openssl rand -base64 24
DB_PASSWORD=
DB_NAME=omnia
DATABASE_URI=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# === Redis ===
# Generieren: openssl rand -base64 24
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# === Verschluesselung ===
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Optional: Salt fuer Key-Ableitung
ENCRYPTION_SALT=
# Generieren: openssl rand -base64 32
AUDIT_HMAC_KEY=

# === Anthropic KI ===
# Von console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Web ===
WEB_PORT=8000
